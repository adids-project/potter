# Copy this file to `.env.shipper` on the sensor node.
# Never commit the generated `.env.shipper`.

# Remote Elasticsearch endpoint on the ELK machine.
ELASTIC_HOSTS=https://replace-with-elk-private-host:9200

# Create this user on the ELK machine with:
#   make es-create-cowrie-live-shipper-user
ELASTIC_USER=zeek_cowrie_live_shipper
ELASTIC_PASSWORD=replace-with-shipper-password

# Logical sensor identifier attached to shipped events.
SENSOR_ID=zeek-cowrie-live-01
